{
  "tabWidth": 2,
  "useTabs": false,
  "printWidth": 120,
  "bracketSameLine": true,
  "plugins": ["prettier-plugin-go-template", "prettier-plugin-tailwindcss"],
  "overrides": [
    {
      "files": ["*.html"],
      "options": {
        "parser": "go-template",
        "bracketSameLine": true
      }
    }
  ]
}